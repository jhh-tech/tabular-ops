<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="Bg0Color">#0A0D10</Color>
    <Color x:Key="Bg1Color">#11151A</Color>
    <Color x:Key="Bg2Color">#161B21</Color>
    <Color x:Key="Bg3Color">#1E242C</Color>

    <SolidColorBrush x:Key="Bg0" Color="{StaticResource Bg0Color}" />
    <SolidColorBrush x:Key="Bg1" Color="{StaticResource Bg1Color}" />
    <SolidColorBrush x:Key="Bg2" Color="{StaticResource Bg2Color}" />
    <SolidColorBrush x:Key="Bg3" Color="{StaticResource Bg3Color}" />

    <!-- Borders -->
    <Color x:Key="BorderColor">#2A313B</Color>
    <Color x:Key="BorderStrongColor">#3A424E</Color>

    <SolidColorBrush x:Key="Border" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderStrong" Color="{StaticResource BorderStrongColor}" />

    <!-- Text -->
    <Color x:Key="Text0Color">#E8ECEF</Color>
    <Color x:Key="Text1Color">#AAB3BD</Color>
    <Color x:Key="Text2Color">#6B7684</Color>
    <Color x:Key="Text3Color">#4A5360</Color>

    <SolidColorBrush x:Key="Text0" Color="{StaticResource Text0Color}" />
    <SolidColorBrush x:Key="Text1" Color="{StaticResource Text1Color}" />
    <SolidColorBrush x:Key="Text2" Color="{StaticResource Text2Color}" />
    <SolidColorBrush x:Key="Text3" Color="{StaticResource Text3Color}" />

    <!-- Semantic -->
    <Color x:Key="AccentColor">#4EC9B0</Color>
    <Color x:Key="AccentDimColor">#2F7A6A</Color>
    <Color x:Key="WarnColor">#E4A853</Color>
    <Color x:Key="ErrorColor">#E06C75</Color>
    <Color x:Key="SuccessColor">#98C379</Color>
    <Color x:Key="InfoColor">#61AFEF</Color>
    <Color x:Key="InfoDimColor">#2A5070</Color>
    <Color x:Key="VioletColor">#C586C0</Color>

    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentDim" Color="{StaticResource AccentDimColor}" />
    <SolidColorBrush x:Key="Warn" Color="{StaticResource WarnColor}" />
    <SolidColorBrush x:Key="Error" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="Success" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="Info" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="InfoDim" Color="{StaticResource InfoDimColor}" />
    <SolidColorBrush x:Key="Violet" Color="{StaticResource VioletColor}" />

</ResourceDictionary>
