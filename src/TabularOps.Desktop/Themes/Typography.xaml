<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Fonts are embedded as Resource in TabularOps.Desktop.csproj.
        Files must exist at: Assets/Fonts/IBMPlexSans-*.ttf and JetBrainsMono-*.ttf
        Register by placing .ttf files there; no further code needed.
    -->

    <FontFamily x:Key="SansFont">
        pack://application:,,,/Assets/Fonts/#IBM Plex Sans
    </FontFamily>

    <FontFamily x:Key="MonoFont">
        pack://application:,,,/Assets/Fonts/#JetBrains Mono
    </FontFamily>

    <!-- Common sizes -->
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeSmall">11</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeNormal">12</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeLarge">13</sys:Double>

</ResourceDictionary>
