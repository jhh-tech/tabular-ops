<Window x:Class="TabularOps.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TabularOps.Desktop.ViewModels"
        xmlns:views="clr-namespace:TabularOps.Desktop.Views"
        mc:Ignorable="d"
        Title="Tabular Ops"
        Icon="pack://application:,,,/Assets/app.ico"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource Bg0}"
        WindowStyle="SingleBorderWindow">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddConnectionCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Topbar: 38px -->
            <RowDefinition Height="38" />
            <!-- Content area -->
            <RowDefinition Height="*" />
            <!-- Status bar: 22px -->
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════ TOPBAR ═══════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg1}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- Logo -->
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />  <!-- Tenant indicator -->
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />  <!-- Theme toggle -->
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />  <!-- Add connection -->
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <TextBlock Grid.Column="0"
                           Text="TABULAR OPS"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="{DynamicResource Accent}"
                           VerticalAlignment="Center" />

                <!-- Active tenant pill -->
                <Border Grid.Column="2"
                        Background="{DynamicResource Bg3}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10,3"
                        VerticalAlignment="Center"
                        Visibility="{Binding ActiveTenant, Converter={StaticResource NullToCollapsedConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Connection status dot -->
                        <Ellipse Width="6" Height="6" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource Success}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveTenant.Status}"
                                                     Value="{x:Static vm:TenantConnectionStatus.Error}">
                                            <Setter Property="Fill" Value="{DynamicResource Error}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveTenant.Status}"
                                                     Value="{x:Static vm:TenantConnectionStatus.ReadOnly}">
                                            <Setter Property="Fill" Value="{DynamicResource Warn}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveTenant.Status}"
                                                     Value="{x:Static vm:TenantConnectionStatus.Connecting}">
                                            <Setter Property="Fill" Value="{DynamicResource Text3}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ActiveTenant.DisplayName}"
                                   FontFamily="{StaticResource SansFont}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text0}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=" · "
                                   FontFamily="{StaticResource SansFont}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text2}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding ActiveModel, Converter={StaticResource NullToCollapsedConverter}}" />
                        <TextBlock Text="{Binding ActiveModel.DisplayName}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text1}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding ActiveModel, Converter={StaticResource NullToCollapsedConverter}}" />
                    </StackPanel>
                </Border>

                <!-- Theme toggle -->
                <Button x:Name="ThemeToggleButton"
                        Grid.Column="4"
                        Style="{StaticResource FlatButton}"
                        Click="ThemeToggle_Click"
                        ToolTip="Toggle light / dark theme"
                        FontFamily="{StaticResource MonoFont}"
                        FontSize="12"
                        VerticalAlignment="Center" />

                <!-- Add connection button -->
                <Button Grid.Column="6"
                        Content="+ Connect  Ctrl+N"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding AddConnectionCommand}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ═══════════════════════════════ MAIN CONTENT ═══════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ─── SIDEBAR ─── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Bg1}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Restore progress bar — shown while connections are loading on startup -->
                    <Border Grid.Row="0"
                            Height="2"
                            VerticalAlignment="Top"
                            Visibility="{Binding IsRestoring, Converter={StaticResource BoolToVisibleConverter}}"
                            Panel.ZIndex="1">
                        <Rectangle Fill="{DynamicResource Accent}">
                            <Rectangle.Triggers>
                                <EventTrigger RoutedEvent="Rectangle.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="0.3" To="1.0"
                                                Duration="0:0:0.9"
                                                AutoReverse="True" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Rectangle.Triggers>
                        </Rectangle>
                    </Border>

                    <!-- Model tree -->
                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>

                        <!-- Entra account header — visible once UPN is resolved -->
                        <Border x:Name="EntraHeader"
                                Padding="12,8,4,4"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="0,0,0,1"
                                Visibility="{Binding EntraAccount, Converter={StaticResource NullToCollapsedConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding EntraAccount}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="9"
                                           Foreground="{DynamicResource Text3}"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="Sign out"
                                        ToolTip="Sign out of Microsoft account and remove all Power BI workspaces"
                                        Style="{StaticResource FlatButton}"
                                        FontSize="9"
                                        Foreground="{DynamicResource Text3}"
                                        BorderThickness="0"
                                        Padding="5,2"
                                        Command="{Binding SignOutPowerBiCommand}"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsMouseOver,
                                                     RelativeSource={RelativeSource AncestorType=Border},
                                                     Converter={StaticResource BoolToVisibleConverter}}" />
                            </Grid>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Tenants}" Margin="0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TenantNodeViewModel}">
                                    <StackPanel Margin="0,4,0,0">
                                        <!-- Tenant header -->
                                        <Border x:Name="TenantHeader"
                                                Padding="12,4,4,4"
                                                Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Status dot + name -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                                 VerticalAlignment="Center">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="{DynamicResource Success}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                     Value="{x:Static vm:TenantConnectionStatus.Error}">
                                                                            <Setter Property="Fill" Value="{DynamicResource Error}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                     Value="{x:Static vm:TenantConnectionStatus.ReadOnly}">
                                                                            <Setter Property="Fill" Value="{DynamicResource Warn}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                     Value="{x:Static vm:TenantConnectionStatus.Connecting}">
                                                                            <Setter Property="Fill" Value="{DynamicResource Text3}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontFamily="{StaticResource SansFont}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource Text2}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <!-- UPN: which Entra account owns this workspace -->
                                                    <TextBlock Text="{Binding UserPrincipalName}"
                                                               FontFamily="{StaticResource MonoFont}"
                                                               FontSize="9"
                                                               Foreground="{DynamicResource Text3}"
                                                               Margin="12,1,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding UserPrincipalName}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Remove × button — visible on hover of parent Border -->
                                                <Button Grid.Column="1"
                                                        Content="✕"
                                                        ToolTip="Remove connection"
                                                        Style="{StaticResource FlatButton}"
                                                        FontSize="10"
                                                        Foreground="{DynamicResource Text3}"
                                                        BorderThickness="0"
                                                        Padding="5,2"
                                                        Command="{Binding DataContext.RemoveTenantCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsMouseOver,
                                                                     RelativeSource={RelativeSource AncestorType=Border},
                                                                     Converter={StaticResource BoolToVisibleConverter}}" />
                                            </Grid>

                                            <!-- Show × on hover -->
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Bg2}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <!-- Model list -->
                                        <ItemsControl ItemsSource="{Binding Models}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ModelNodeViewModel}">
                                                    <Border Padding="28,5,12,5"
                                                            Cursor="Hand">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.SelectModelCommand,
                                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          CommandParameter="{Binding}" />
                                                        </Border.InputBindings>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource Bg3}" />
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource Bg2}" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource Text0}" />
                                                            <TextBlock Text="{Binding WorkspaceName}"
                                                                       FontFamily="{StaticResource SansFont}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource Text2}"
                                                                       Margin="0,1,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Separator between tenants -->
                                        <Border Height="1" Background="{DynamicResource Border}"
                                                Margin="12,8,12,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="16"
                                Visibility="{Binding Tenants.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                        <TextBlock Text="No connections"
                                   FontFamily="{StaticResource SansFont}"
                                   FontSize="12"
                                   Foreground="{DynamicResource Text2}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Press Ctrl+N to add one"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource Text3}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Sidebar footer: Add connection -->
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="0,1,0,0">
                        <Button Content="+ Connect"
                                Style="{StaticResource FlatButton}"
                                Command="{Binding AddConnectionCommand}"
                                BorderThickness="0"
                                Padding="12,8"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left" />
                    </Border>
                </Grid>
            </Border>

            <!-- Resize grip -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource Border}"
                          Cursor="SizeWE" />

            <!-- ─── MAIN CONTENT AREA ─── -->
            <Grid Grid.Column="2" Background="{DynamicResource Bg0}">

                <!-- Empty state: no model selected -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding ActiveModel, Converter={StaticResource NullToVisibleConverter}}">
                    <TextBlock Text="Select a model to get started"
                               FontFamily="{StaticResource SansFont}"
                               FontSize="13"
                               Foreground="{DynamicResource Text2}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Choose a model from the sidebar"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{DynamicResource Text3}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" />
                </StackPanel>

                <!-- Tab host: visible when a model is active -->
                <Grid Visibility="{Binding ActiveModel, Converter={StaticResource NullToCollapsedConverter}}">
                    <Grid.RowDefinitions>
                        <!-- Model context bar -->
                        <RowDefinition Height="Auto" />
                        <!-- Tab strip -->
                        <RowDefinition Height="36" />
                        <!-- Tab content -->
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- ── Model context bar ── -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource Bg0}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="0,0,0,1"
                            Padding="16,0"
                            Height="32">
                        <Grid>
                            <!-- Left: workspace + model details -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                <!-- Workspace name -->
                                <TextBlock Text="{Binding ActiveModel.Model.WorkspaceName}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text1}" />

                                <TextBlock Text=" · "
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Text3}" />

                                <!-- Endpoint type -->
                                <TextBlock Text="{Binding ActiveEndpointLabel}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Text2}" />

                                <TextBlock Text=" · "
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Text3}" />

                                <!-- Compatibility level -->
                                <TextBlock Text="{Binding ActiveCompatibilityLabel}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Text2}" />

                                <TextBlock FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Text3}">
                                    <Run Text=" · " />
                                    <Run Text="{Binding ActiveWorkspaceModelCount, Mode=OneWay}" />
                                    <Run Text=" models" />
                                </TextBlock>

                                <!-- Total model size — only shown once DMV stats are loaded -->
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding PartitionMap.TotalModelSize, Converter={StaticResource NullToCollapsedConverter}}">
                                    <TextBlock Text=" · "
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text3}" />
                                    <TextBlock Text="{Binding PartitionMap.TotalModelSize}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text2}" />
                                </StackPanel>

                                <!-- Capacity info — only shown for Power BI workspaces with known capacity -->
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding HasCapacityInfo, Converter={StaticResource BoolToVisibleConverter}}">

                                    <TextBlock Text=" · "
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text3}" />

                                    <!-- SKU badge -->
                                    <Border Background="{DynamicResource AccentDim}"
                                            CornerRadius="2"
                                            Padding="5,1">
                                        <TextBlock Text="{Binding ActiveCapacitySku}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Accent}" />
                                    </Border>

                                    <!-- Capacity name -->
                                    <TextBlock Text="{Binding ActiveCapacityName}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text2}"
                                               Margin="6,0,0,0" />

                                    <!-- Region -->
                                    <TextBlock Text=" · "
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text3}" />

                                    <TextBlock Text="{Binding ActiveCapacityRegion}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text3}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Tab strip ── -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource Bg1}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Content="PARTITIONS"
                                          Style="{StaticResource TabButton}"
                                          IsChecked="{Binding IsPartitionsTab, Mode=OneWay}"
                                          Command="{Binding SwitchTabCommand}"
                                          CommandParameter="Partitions" />
                            <ToggleButton Content="TRACE"
                                          Style="{StaticResource TabButton}"
                                          IsEnabled="False" />
                            <ToggleButton Content="HISTORY"
                                          Style="{StaticResource TabButton}"
                                          IsChecked="{Binding IsHistoryTab, Mode=OneWay}"
                                          Command="{Binding SwitchTabCommand}"
                                          CommandParameter="History" />
                            <ToggleButton Content="SESSIONS"
                                          Style="{StaticResource TabButton}"
                                          IsEnabled="False" />
                        </StackPanel>
                    </Border>

                    <!-- ── Tab content ── -->
                    <!-- Each tab is wrapped in a Grid so Visibility binds to MainViewModel
                         (the parent DataContext), not to the view's own DataContext. -->
                    <Grid Grid.Row="2">
                        <Grid Visibility="{Binding IsPartitionsTab, Converter={StaticResource BoolToVisibleConverter}}">
                            <views:PartitionMapView DataContext="{Binding PartitionMap}" />
                        </Grid>
                        <Grid Visibility="{Binding IsHistoryTab, Converter={StaticResource BoolToVisibleConverter}}">
                            <views:HistoryView DataContext="{Binding History}" />
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════ STATUS BAR ═══════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource Bg1}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Connection state -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusBar.ConnectionState}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="10"
                           Foreground="{DynamicResource Text2}"
                           VerticalAlignment="Center" />

                <!-- Endpoint type -->
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusBar.EndpointLabel}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="10"
                           Foreground="{DynamicResource Text3}"
                           VerticalAlignment="Center" />

                <!-- Read-only badge -->
                <Border Grid.Column="4"
                        Background="{DynamicResource Bg3}"
                        BorderBrush="{DynamicResource Warn}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="6,1"
                        VerticalAlignment="Center"
                        Visibility="{Binding StatusBar.IsReadOnly, Converter={StaticResource BoolToVisibleConverter}}">
                    <TextBlock Text="READ-ONLY"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Warn}" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
