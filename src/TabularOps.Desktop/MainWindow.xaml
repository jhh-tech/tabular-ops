<Window x:Class="TabularOps.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TabularOps.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="Tabular Ops"
        Icon="pack://application:,,,/Assets/app.ico"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource Bg0}"
        WindowStyle="SingleBorderWindow">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddConnectionCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Topbar: 38px -->
            <RowDefinition Height="38" />
            <!-- Content area -->
            <RowDefinition Height="*" />
            <!-- Status bar: 22px -->
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════ TOPBAR ═══════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource Bg1}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />  <!-- Logo -->
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />  <!-- Tenant indicator -->
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />  <!-- User / connection info -->
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <TextBlock Grid.Column="0"
                           Text="TABULAR OPS"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="{StaticResource Accent}"
                           VerticalAlignment="Center" />

                <!-- Active tenant pill -->
                <Border Grid.Column="2"
                        Background="{StaticResource Bg3}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="10,3"
                        VerticalAlignment="Center"
                        Visibility="{Binding ActiveTenant, Converter={StaticResource NullToCollapsedConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Connection status dot -->
                        <Ellipse Width="6" Height="6" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Success}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ActiveTenant.Status}"
                                                     Value="{x:Static vm:TenantConnectionStatus.Error}">
                                            <Setter Property="Fill" Value="{StaticResource Error}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveTenant.Status}"
                                                     Value="{x:Static vm:TenantConnectionStatus.ReadOnly}">
                                            <Setter Property="Fill" Value="{StaticResource Warn}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ActiveTenant.Status}"
                                                     Value="{x:Static vm:TenantConnectionStatus.Connecting}">
                                            <Setter Property="Fill" Value="{StaticResource Text3}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding ActiveTenant.DisplayName}"
                                   FontFamily="{StaticResource SansFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource Text0}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=" · "
                                   FontFamily="{StaticResource SansFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource Text2}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding ActiveModel, Converter={StaticResource NullToCollapsedConverter}}" />
                        <TextBlock Text="{Binding ActiveModel.DisplayName}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource Text1}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding ActiveModel, Converter={StaticResource NullToCollapsedConverter}}" />
                    </StackPanel>
                </Border>

                <!-- Add connection button -->
                <Button Grid.Column="4"
                        Content="+ Connect  Ctrl+N"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding AddConnectionCommand}"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ═══════════════════════════════ MAIN CONTENT ═══════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ─── SIDEBAR ─── -->
            <Border Grid.Column="0"
                    Background="{StaticResource Bg1}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Model tree -->
                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Tenants}" Margin="0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:TenantNodeViewModel}">
                                    <StackPanel Margin="0,4,0,0">
                                        <!-- Tenant header -->
                                        <Border Padding="12,4" Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource Success}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}"
                                                                             Value="{x:Static vm:TenantConnectionStatus.Error}">
                                                                    <Setter Property="Fill" Value="{StaticResource Error}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}"
                                                                             Value="{x:Static vm:TenantConnectionStatus.ReadOnly}">
                                                                    <Setter Property="Fill" Value="{StaticResource Warn}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}"
                                                                             Value="{x:Static vm:TenantConnectionStatus.Connecting}">
                                                                    <Setter Property="Fill" Value="{StaticResource Text3}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontFamily="{StaticResource SansFont}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource Text2}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Model list -->
                                        <ItemsControl ItemsSource="{Binding Models}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:ModelNodeViewModel}">
                                                    <Border Padding="28,5,12,5"
                                                            Cursor="Hand">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.SelectModelCommand,
                                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          CommandParameter="{Binding}" />
                                                        </Border.InputBindings>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource Bg3}" />
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource Bg2}" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource Text0}" />
                                                            <TextBlock Text="{Binding WorkspaceName}"
                                                                       FontFamily="{StaticResource SansFont}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource Text2}"
                                                                       Margin="0,1,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Separator between tenants -->
                                        <Border Height="1" Background="{StaticResource Border}"
                                                Margin="12,8,12,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="16"
                                Visibility="{Binding Tenants.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                        <TextBlock Text="No connections"
                                   FontFamily="{StaticResource SansFont}"
                                   FontSize="12"
                                   Foreground="{StaticResource Text2}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Press Ctrl+N to add one"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="11"
                                   Foreground="{StaticResource Text3}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Sidebar footer: Add connection -->
                    <Border Grid.Row="1"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="0,1,0,0">
                        <Button Content="+ Connect"
                                Style="{StaticResource FlatButton}"
                                Command="{Binding AddConnectionCommand}"
                                BorderThickness="0"
                                Padding="12,8"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left" />
                    </Border>
                </Grid>
            </Border>

            <!-- Resize grip -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource Border}"
                          Cursor="SizeWE" />

            <!-- ─── MAIN CONTENT AREA ─── -->
            <Border Grid.Column="2" Background="{StaticResource Bg0}">
                <!-- Placeholder — replaced by tab host in Milestone 2 -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding ActiveModel, Converter={StaticResource NullToVisibleConverter}}">
                    <TextBlock Text="Select a model to get started"
                               FontFamily="{StaticResource SansFont}"
                               FontSize="13"
                               Foreground="{StaticResource Text2}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════ STATUS BAR ═══════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource Bg1}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Connection state -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusBar.ConnectionState}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="10"
                           Foreground="{StaticResource Text2}"
                           VerticalAlignment="Center" />

                <!-- Endpoint type -->
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusBar.EndpointLabel}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="10"
                           Foreground="{StaticResource Text3}"
                           VerticalAlignment="Center" />

                <!-- Read-only badge -->
                <Border Grid.Column="4"
                        Background="{StaticResource Bg3}"
                        BorderBrush="{StaticResource Warn}"
                        BorderThickness="1"
                        CornerRadius="2"
                        Padding="6,1"
                        VerticalAlignment="Center"
                        Visibility="{Binding StatusBar.IsReadOnly, Converter={StaticResource BoolToVisibleConverter}}">
                    <TextBlock Text="READ-ONLY"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{StaticResource Warn}" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
