<Window x:Class="TabularOps.Desktop.Views.AddConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Connection"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg1}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Heading -->
        <TextBlock Grid.Row="0"
                   Text="Add Connection"
                   FontFamily="{StaticResource SansFont}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource Text0}" />

        <!-- Type selector -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="TYPE"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="10"
                       Foreground="{StaticResource Text2}"
                       Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RadioPowerBi" Content="Power BI / Fabric"
                             GroupName="EndpointType" IsChecked="True"
                             FontFamily="{StaticResource SansFont}"
                             Foreground="{StaticResource Text0}"
                             Margin="0,0,24,0" />
                <RadioButton x:Name="RadioSsas" Content="SSAS / AAS"
                             GroupName="EndpointType"
                             FontFamily="{StaticResource SansFont}"
                             Foreground="{StaticResource Text0}" />
            </StackPanel>
        </StackPanel>

        <!-- ── Power BI panel ── -->
        <StackPanel x:Name="PanelPowerBi" Grid.Row="4">

            <!-- Step 1: Sign in -->
            <StackPanel x:Name="StepSignIn">
                <TextBlock FontFamily="{StaticResource SansFont}"
                           FontSize="12"
                           Foreground="{StaticResource Text1}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12">
                    Sign in to load the workspaces you have access to.
                </TextBlock>
                <Button x:Name="BtnSignIn"
                        Content="Sign In"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Left"
                        Click="OnSignIn" />
            </StackPanel>

            <!-- Step 2: Workspace picker -->
            <StackPanel x:Name="StepWorkspacePicker" Visibility="Collapsed">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="WORKSPACES"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{StaticResource Text2}"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="TxtSelectionCount"
                               Grid.Column="1"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{StaticResource Accent}"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </Grid>

                <!-- Search -->
                <TextBox x:Name="TxtSearch"
                         FontFamily="{StaticResource SansFont}"
                         FontSize="12"
                         Foreground="{StaticResource Text0}"
                         Background="{StaticResource Bg2}"
                         BorderBrush="{StaticResource Border}"
                         BorderThickness="1"
                         Padding="8,5"
                         Margin="0,0,0,4"
                         TextChanged="OnSearchChanged" />

                <!-- Workspace checkbox list -->
                <Border BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        MaxHeight="220">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="{StaticResource Bg2}">
                        <StackPanel x:Name="WorkspaceList" />
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- ── SSAS panel ── -->
        <StackPanel x:Name="PanelSsas" Grid.Row="5" Visibility="Collapsed">
            <TextBlock Text="DISPLAY NAME"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="10"
                       Foreground="{StaticResource Text2}"
                       Margin="0,0,0,4" />
            <TextBox x:Name="TxtDisplayName"
                     FontFamily="{StaticResource SansFont}"
                     FontSize="12"
                     Foreground="{StaticResource Text0}"
                     Background="{StaticResource Bg2}"
                     BorderBrush="{StaticResource Border}"
                     BorderThickness="1"
                     Padding="8,5"
                     Margin="0,0,0,12" />

            <TextBlock Text="CONNECTION STRING"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="10"
                       Foreground="{StaticResource Text2}"
                       Margin="0,0,0,4" />
            <TextBox x:Name="TxtConnectionString"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="11"
                     Foreground="{StaticResource Text0}"
                     Background="{StaticResource Bg2}"
                     BorderBrush="{StaticResource Border}"
                     BorderThickness="1"
                     Padding="8,5"
                     TextWrapping="Wrap" />
            <TextBlock Text="e.g. Data Source=myserver\tabular;Initial Catalog=MyModel"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="10"
                       Foreground="{StaticResource Text3}"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Error -->
        <TextBlock x:Name="TxtError"
                   Grid.Row="6"
                   FontFamily="{StaticResource SansFont}"
                   FontSize="11"
                   Foreground="{StaticResource Error}"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"
                   Visibility="Collapsed" />

        <!-- Buttons -->
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource FlatButton}"
                    Margin="0,0,8,0"
                    Click="OnCancel" />
            <Button x:Name="BtnConnect"
                    Content="Connect"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="False"
                    Click="OnConnect" />
        </StackPanel>
    </Grid>
</Window>
