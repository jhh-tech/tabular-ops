<Window x:Class="TabularOps.Desktop.Views.RefreshConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Refresh"
        Width="440"
        SizeToContent="Height"
        MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource Bg1}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Typography.xaml" />
                <ResourceDictionary Source="/Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <StackPanel Margin="24">

        <!-- Title -->
        <TextBlock Text="Confirm Refresh"
                   FontFamily="{StaticResource SansFont}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource Text0}" />

        <!-- Summary line -->
        <TextBlock Text="{Binding Summary}"
                   FontFamily="{StaticResource MonoFont}"
                   FontSize="11"
                   Foreground="{DynamicResource Text2}"
                   Margin="0,6,0,0" />

        <!-- Refresh type -->
        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <TextBlock Text="Type:"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="11"
                       Foreground="{DynamicResource Text3}"
                       Width="64" />
            <TextBlock Text="{Binding RefreshTypeName}"
                       FontFamily="{StaticResource MonoFont}"
                       FontSize="11"
                       Foreground="{DynamicResource Accent}" />
        </StackPanel>

        <!-- Divider -->
        <Border Height="1"
                Background="{DynamicResource Border}"
                Margin="0,14,0,12" />

        <!-- Table / partition list -->
        <ScrollViewer MaxHeight="300"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Tables}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,10">
                            <!-- Table name -->
                            <TextBlock Text="{Binding TableName}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource Text0}" />
                            <!-- Partition list -->
                            <ItemsControl ItemsSource="{Binding Partitions}"
                                          Margin="12,3,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource Text2}"
                                                   Margin="0,1,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Divider -->
        <Border Height="1"
                Background="{DynamicResource Border}"
                Margin="0,12,0,14" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource FlatButton}"
                    Width="80"
                    Margin="0,0,8,0"
                    IsCancel="True" />
            <Button Content="Refresh"
                    Style="{StaticResource PrimaryButton}"
                    Width="80"
                    IsDefault="True"
                    Click="Confirm_Click" />
        </StackPanel>

    </StackPanel>
</Window>
