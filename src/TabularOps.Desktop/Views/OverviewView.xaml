<UserControl x:Class="TabularOps.Desktop.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TabularOps.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900"
             Background="{DynamicResource Bg0}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <!-- 2px progress bar — collapsed when idle -->
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg1}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Process model dropdown -->
                    <ToggleButton x:Name="ProcessToggle"
                                  Style="{StaticResource FlatToggleButton}"
                                  FontFamily="{StaticResource MonoFont}"
                                  FontSize="11"
                                  IsEnabled="{Binding CanProcess}"
                                  IsChecked="{Binding IsProcessPopupOpen, Mode=TwoWay}"
                                  Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳ Process model" VerticalAlignment="Center" />
                            <TextBlock Text=" ▾" Foreground="{DynamicResource Text3}" VerticalAlignment="Center" />
                        </StackPanel>
                    </ToggleButton>

                    <Popup IsOpen="{Binding IsProcessPopupOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=ProcessToggle}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="{DynamicResource Bg2}"
                                BorderBrush="{DynamicResource BorderStrong}"
                                BorderThickness="1"
                                Padding="4">
                            <StackPanel>
                                <Button Style="{StaticResource FlatButton}"
                                        Command="{Binding ProcessModelWithModeCommand}"
                                        CommandParameter="{Binding [0], Source={x:Static vm:PartitionMapViewModel.RefreshTypeOptions}}"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,5" FontFamily="{StaticResource MonoFont}" FontSize="11">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⟳ Default" />
                                        <TextBlock Text="  (Automatic)" Foreground="{DynamicResource Text3}" />
                                    </StackPanel>
                                </Button>
                                <Button Content="⟳ Full"
                                        Style="{StaticResource FlatButton}"
                                        Command="{Binding ProcessModelWithModeCommand}"
                                        CommandParameter="{Binding [1], Source={x:Static vm:PartitionMapViewModel.RefreshTypeOptions}}"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,5" FontFamily="{StaticResource MonoFont}" FontSize="11" />
                                <Button Content="⟳ Data only"
                                        Style="{StaticResource FlatButton}"
                                        Command="{Binding ProcessModelWithModeCommand}"
                                        CommandParameter="{Binding [2], Source={x:Static vm:PartitionMapViewModel.RefreshTypeOptions}}"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,5" FontFamily="{StaticResource MonoFont}" FontSize="11" />
                                <Button Content="⟳ Calculate"
                                        Style="{StaticResource FlatButton}"
                                        Command="{Binding ProcessModelWithModeCommand}"
                                        CommandParameter="{Binding [3], Source={x:Static vm:PartitionMapViewModel.RefreshTypeOptions}}"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,5" FontFamily="{StaticResource MonoFont}" FontSize="11" />
                                <Border Height="1" Background="{DynamicResource Border}" Margin="6,2" />
                                <Button Content="⟳ Clear values"
                                        Style="{StaticResource FlatButton}"
                                        Command="{Binding ProcessModelWithModeCommand}"
                                        CommandParameter="{Binding [4], Source={x:Static vm:PartitionMapViewModel.RefreshTypeOptions}}"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,5" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                        Foreground="{DynamicResource Warn}" />
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Separator -->
                    <Border Width="1" Height="18" Background="{DynamicResource Border}" Margin="8,0" VerticalAlignment="Center" />

                    <!-- Backup -->
                    <Button Style="{StaticResource FlatButton}"
                            Command="{Binding BackupModelCommand}"
                            IsEnabled="{Binding CanBackup}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            ToolTip="Backup this model to the configured server storage (Azure Blob / OneLake)">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="⬛ Backup model" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBackingUp}" Value="True">
                                            <Setter Property="Text" Value="⬛ Backing up…" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                    <!-- Process status -->
                    <TextBlock Text="{Binding ProcessStatus}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProcessStatus}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Operation progress bar (indeterminate, 2px) ── -->
        <ProgressBar Grid.Row="1"
                     Height="2"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource Accent}"
                     Background="Transparent"
                     BorderThickness="0"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibleConverter}}" />

        <!-- ── Content ── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Loading -->
                <TextBlock Text="Loading…"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="12"
                           Foreground="{DynamicResource Text2}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibleConverter}}" />

                <!-- Error -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="32"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}">
                    <TextBlock Text="Failed to load model info"
                               FontFamily="{StaticResource SansFont}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource Error}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontFamily="{StaticResource MonoFont}" FontSize="11"
                               Foreground="{DynamicResource Text2}" HorizontalAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="480" Margin="0,8,0,0" />
                </StackPanel>

                <!-- Main content -->
                <StackPanel Margin="20,16,20,16">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- ── Metric cards ── -->
                    <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">
                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="4" Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalSize}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="22" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text0}" />
                                <TextBlock Text="compressed size"
                                           FontFamily="{StaticResource SansFont}" FontSize="11"
                                           Foreground="{DynamicResource Text3}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="4" Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding TotalRows}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="22" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text0}" />
                                <TextBlock Text="total rows"
                                           FontFamily="{StaticResource SansFont}" FontSize="11"
                                           Foreground="{DynamicResource Text3}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="4" Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{Binding PartitionCount}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="22" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text0}" />
                                <TextBlock Text="partitions"
                                           FontFamily="{StaticResource SansFont}" FontSize="11"
                                           Foreground="{DynamicResource Text3}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="4" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="{Binding TableCount}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="22" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text0}" />
                                <TextBlock Text="tables"
                                           FontFamily="{StaticResource SansFont}" FontSize="11"
                                           Foreground="{DynamicResource Text3}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- ── Detail rows ── -->
                    <Border Background="{DynamicResource Bg2}" BorderBrush="{DynamicResource Border}"
                            BorderThickness="1" CornerRadius="4">
                        <StackPanel>

                            <!-- Last processed -->
                            <Grid Margin="16,10,16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Last processed"
                                           FontFamily="{StaticResource SansFont}" FontSize="12"
                                           Foreground="{DynamicResource Text2}" />
                                <TextBlock Grid.Column="1" Text="{Binding LastProcessed}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12"
                                           Foreground="{DynamicResource Text1}" />
                            </Grid>
                            <Border Height="1" Background="{DynamicResource Border}" Margin="16,0" />

                            <!-- Last backup -->
                            <Grid Margin="16,10,16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Last backup"
                                           FontFamily="{StaticResource SansFont}" FontSize="12"
                                           Foreground="{DynamicResource Text2}" />
                                <TextBlock Grid.Column="1" Text="{Binding LastBackup}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12"
                                           Foreground="{DynamicResource Text1}" />
                            </Grid>
                            <Border Height="1" Background="{DynamicResource Border}" Margin="16,0" />

                            <!-- Memory usage -->
                            <Grid Margin="16,10,16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Memory usage"
                                           FontFamily="{StaticResource SansFont}" FontSize="12"
                                           Foreground="{DynamicResource Text2}" />
                                <TextBlock Grid.Column="1" Text="{Binding MemoryUsage}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12"
                                           Foreground="{DynamicResource Text1}" />
                            </Grid>
                            <Border Height="1" Background="{DynamicResource Border}" Margin="16,0" />

                            <!-- Compatibility level -->
                            <Grid Margin="16,10,16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Compatibility level"
                                           FontFamily="{StaticResource SansFont}" FontSize="12"
                                           Foreground="{DynamicResource Text2}" />
                                <TextBlock Grid.Column="1" Text="{Binding CompatibilityLevel}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12"
                                           Foreground="{DynamicResource Text1}" />
                            </Grid>
                            <Border Height="1" Background="{DynamicResource Border}" Margin="16,0" />

                            <!-- Endpoint -->
                            <Grid Margin="16,10,16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Endpoint type"
                                           FontFamily="{StaticResource SansFont}" FontSize="12"
                                           Foreground="{DynamicResource Text2}" />
                                <TextBlock Grid.Column="1" Text="{Binding EndpointType}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="12"
                                           Foreground="{DynamicResource Text1}" />
                            </Grid>

                            <!-- Capacity — only shown for Power BI workspaces on named capacity -->
                            <Border Visibility="{Binding HasCapacityInfo, Converter={StaticResource BoolToVisibleConverter}}">
                                <StackPanel>
                                    <Border Height="1" Background="{DynamicResource Border}" Margin="16,0" />
                                    <Grid Margin="16,10,16,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Capacity"
                                                   FontFamily="{StaticResource SansFont}" FontSize="12"
                                                   Foreground="{DynamicResource Text2}" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <!-- SKU badge -->
                                            <Border Background="{DynamicResource AccentDim}"
                                                    CornerRadius="2" Padding="6,1" Margin="0,0,8,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CapacitySku}"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource Accent}" />
                                            </Border>
                                            <TextBlock Text="{Binding CapacityName}"
                                                       FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                       Foreground="{DynamicResource Text1}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text=" · "
                                                       FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                       Foreground="{DynamicResource Text3}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding CapacityRegion}"
                                                       FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                       Foreground="{DynamicResource Text3}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
