<UserControl x:Class="TabularOps.Desktop.Views.PartitionMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TabularOps.Desktop.ViewModels"
             xmlns:model="clr-namespace:TabularOps.Core.Model;assembly=TabularOps.Core"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource Bg0}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar: filter chips + reload -->
            <RowDefinition Height="40" />
            <!-- Content -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════ TOOLBAR ═══════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg1}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">

                <!-- Actions (partition state is conveyed by tile colour, not filter chips) -->
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Selection count + clear -->
                    <TextBlock FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Text3}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding SelectedCount, Mode=OneWay, StringFormat='{}{0} selected'}" />
                        <Run Text=" · " />
                        <Hyperlink Command="{Binding ClearSelectionCommand}"
                                   Foreground="{DynamicResource Text3}">clear</Hyperlink>
                    </TextBlock>

                    <!-- Refresh status text -->
                    <TextBlock Text="{Binding RefreshStatus}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RefreshStatus}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Refresh type picker -->
                    <ComboBox ItemsSource="{Binding RefreshTypeOptions}"
                              SelectedItem="{Binding SelectedRefreshType}"
                              DisplayMemberPath="DisplayName"
                              Width="100"
                              Margin="0,0,4,0"
                              VerticalAlignment="Center"
                              FontFamily="{StaticResource MonoFont}"
                              FontSize="11" />

                    <!-- Refresh Selected -->
                    <Button Content="⟳ Refresh selected"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding RefreshSelectedCommand}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center" />

                    <!-- Reload -->
                    <Button Content="↺ Reload"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding ReloadCommand}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════ CONTENT ═══════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- Pulsing bar: shows for both first-load and background refresh -->
            <Border Height="2" VerticalAlignment="Top" Panel.ZIndex="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBackgroundRefreshing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Rectangle Fill="{DynamicResource Accent}">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Rectangle.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.25" To="1.0"
                                                     Duration="0:0:0.8"
                                                     AutoReverse="True" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
            </Border>

            <!-- Loading indicator (only when no cached data is shown) -->
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibleConverter}}">
                <!-- Centred label -->
                <TextBlock Text="Loading partitions…"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="12"
                           Foreground="{DynamicResource Text2}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Error state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="32"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}">
                <TextBlock Text="Failed to load partitions"
                           FontFamily="{StaticResource SansFont}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Error}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="11"
                           Foreground="{DynamicResource Text2}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="480"
                           Margin="0,8,0,0" />
                <Button Content="Retry"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding ReloadCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0" />
            </StackPanel>

            <!-- Empty filter result -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding VisibleTables.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                <TextBlock Text="No partitions match this filter"
                           FontFamily="{StaticResource SansFont}"
                           FontSize="13"
                           Foreground="{DynamicResource Text2}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Partition table list — hidden while loading or when an error is shown -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4,0,12">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <!-- visible when no error — handled by outer logic -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <ItemsControl ItemsSource="{Binding VisibleTables}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TableViewModel}">

                            <!-- ── TABLE ROW ── -->
                            <Border Margin="12,4,12,0"
                                    BorderBrush="{DynamicResource Border}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Background="{DynamicResource Bg1}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- Fixed info panel -->
                                        <ColumnDefinition Width="148" />
                                        <!-- Partition tiles -->
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- ── LEFT: table info — click to select/deselect all partitions ── -->
                                    <Border Grid.Column="0"
                                            Padding="12,8,10,8"
                                            BorderBrush="{DynamicResource Border}"
                                            BorderThickness="0,0,1,0"
                                            Cursor="Hand"
                                            ToolTip="Click to select / deselect all partitions">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.ToggleTableSelectionCommand,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Bg2}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TableName}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource Text0}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding TableName}" />
                                            <TextBlock Text="{Binding DisplayRowCount}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Text2}"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding DisplaySize}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Text3}" />
                                            <TextBlock Text="{Binding DisplayLastRefreshed}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource Text3}"
                                                       Opacity="0.7"
                                                       Margin="0,5,0,0" />
                                            <TextBlock Text="{Binding PartitionLabel}"
                                                       FontFamily="{StaticResource SansFont}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource Text3}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- ── RIGHT: partition tiles ── -->
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Partitions}" Margin="4,6,6,6">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:PartitionCellViewModel}">

                                                <!-- ── PARTITION CELL ── -->
                                                <Border Width="108" Height="60"
                                                        Margin="2"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        ToolTip="{Binding ToolTip}"
                                                        Cursor="Hand"
                                                        ClipToBounds="True">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.ToggleSelectionCommand,
                                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}" />
                                                    </Border.InputBindings>

                                                    <!-- State-driven border + background -->
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <!-- Default: Ok -->
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.09" />
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Opacity" Value="1.0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}"
                                                                             Value="{x:Static model:PartitionState.Stale}">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Text3}" />
                                                                    <Setter Property="Background" Value="Transparent" />
                                                                    <Setter Property="Opacity" Value="0.55" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}"
                                                                             Value="{x:Static model:PartitionState.Failed}">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Error}" />
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="{DynamicResource ErrorColor}" Opacity="0.09" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}"
                                                                             Value="{x:Static model:PartitionState.Refreshing}">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Info}" />
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="{DynamicResource InfoColor}" Opacity="0.09" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}"
                                                                             Value="{x:Static model:PartitionState.Queued}">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Warn}" />
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="{DynamicResource WarnColor}" Opacity="0.09" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                <!-- Selected: thicker accent border, slightly brighter bg -->
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.18" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <!-- Cell content -->
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <!-- fill bar -->
                                                            <RowDefinition Height="3" />
                                                        </Grid.RowDefinitions>

                                                        <!-- Text content -->
                                                        <StackPanel Grid.Row="0" Margin="6,4,4,2" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding PartitionName}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="10"
                                                                       FontWeight="Medium"
                                                                       Foreground="{DynamicResource Text0}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding PartitionName}" />
                                                            <TextBlock Text="{Binding DisplayRowCount}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="9"
                                                                       Foreground="{DynamicResource Text2}"
                                                                       Margin="0,2,0,0" />
                                                            <TextBlock Text="{Binding DisplaySize}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="9"
                                                                       Foreground="{DynamicResource Text3}" />
                                                            <TextBlock Text="{Binding DisplayLastRefreshed}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="8"
                                                                       Foreground="{DynamicResource Text3}"
                                                                       Opacity="0.7"
                                                                       Margin="0,1,0,0" />
                                                        </StackPanel>

                                                        <!-- Fill bar at bottom -->
                                                        <Border Grid.Row="1"
                                                                x:Name="FillTrack"
                                                                Background="{DynamicResource Bg3}">
                                                            <Border HorizontalAlignment="Left"
                                                                    Background="{DynamicResource AccentDim}">
                                                                <Border.Width>
                                                                    <MultiBinding Converter="{StaticResource RatioWidthMultiConverter}">
                                                                        <Binding Path="ActualWidth"
                                                                                 RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}" />
                                                                        <Binding Path="FillRatio" />
                                                                    </MultiBinding>
                                                                </Border.Width>
                                                            </Border>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </Grid>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </Grid>

</UserControl>
