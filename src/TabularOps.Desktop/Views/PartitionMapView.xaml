<UserControl x:Class="TabularOps.Desktop.Views.PartitionMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TabularOps.Desktop.ViewModels"
             xmlns:model="clr-namespace:TabularOps.Core.Model;assembly=TabularOps.Core"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource Bg0}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Action bar: actions + filter chips + name filter + legend -->
            <RowDefinition Height="38" />
            <!-- Content -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════ ACTION BAR ═══════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg1}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <!-- Refresh selected + separator + Merge/New/Drop -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Fill spacer -->
                    <ColumnDefinition Width="*" />
                    <!-- Filter chips -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Text filter -->
                    <ColumnDefinition Width="156" />
                    <!-- Separator -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Legend -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Separator -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Right actions: Backup + Reload + status -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: Refresh selected | Merge | New partition | Drop -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Refresh selected (accent) -->
                    <Button Style="{StaticResource PrimaryButton}"
                            Command="{Binding RefreshSelectedCommand}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟳ Refresh selected" VerticalAlignment="Center" />
                            <Border Background="{DynamicResource Bg0}"
                                    CornerRadius="2"
                                    Padding="4,1"
                                    Margin="7,0,0,0"
                                    VerticalAlignment="Center"
                                    Opacity="0.6">
                                <TextBlock Text="F5"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="9"
                                           Foreground="{DynamicResource Text0}" />
                            </Border>
                        </StackPanel>
                    </Button>

                    <!-- Separator -->
                    <Border Width="1" Height="18" Background="{DynamicResource Border}"
                            Margin="8,0" VerticalAlignment="Center" />

                    <!-- Merge -->
                    <Button Content="⊞ Merge"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding MergePartitionsCommand}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Margin="0,0,4,0" />

                    <!-- New partition -->
                    <Button Content="+ New partition"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding NewPartitionCommand}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Margin="0,0,4,0" />

                    <!-- Drop -->
                    <Button Style="{StaticResource DangerButton}"
                            Command="{Binding DropPartitionsCommand}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="×"
                                       Foreground="{DynamicResource Error}"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       Margin="0,0,3,0" />
                            <TextBlock Text="Drop"
                                       Foreground="{DynamicResource Error}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Filter chips -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <ToggleButton Style="{StaticResource FilterChip}"
                                  Content="All"
                                  IsChecked="{Binding IsFilterAll, Mode=OneWay}"
                                  Command="{Binding SetFilterCommand}"
                                  CommandParameter="{x:Static vm:PartitionFilter.All}" />
                    <ToggleButton Style="{StaticResource FilterChip}"
                                  Content="Stale"
                                  IsChecked="{Binding IsFilterStale, Mode=OneWay}"
                                  Command="{Binding SetFilterCommand}"
                                  CommandParameter="{x:Static vm:PartitionFilter.Stale}" />
                    <ToggleButton Style="{StaticResource FilterChip}"
                                  Content="Failed"
                                  IsChecked="{Binding IsFilterFailed, Mode=OneWay}"
                                  Command="{Binding SetFilterCommand}"
                                  CommandParameter="{x:Static vm:PartitionFilter.Failed}" />
                    <ToggleButton Style="{StaticResource FilterChip}"
                                  Content="Refreshing"
                                  IsChecked="{Binding IsFilterRefreshing, Mode=OneWay}"
                                  Command="{Binding SetFilterCommand}"
                                  CommandParameter="{x:Static vm:PartitionFilter.Refreshing}" />
                </StackPanel>

                <!-- Text filter -->
                <Border Grid.Column="3"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Background="{DynamicResource Bg2}"
                        VerticalAlignment="Center"
                        Height="24">
                    <Grid>
                        <TextBox x:Name="PartitionFilterBox"
                                 Text="{Binding PartitionNameFilter, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{StaticResource MonoFont}"
                                 FontSize="11"
                                 Foreground="{DynamicResource Text1}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="6,0"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="{DynamicResource Text0}" />
                        <!-- Placeholder + "/" hint -->
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="7,0,6,0"
                                    IsHitTestVisible="False">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PartitionNameFilter}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="filter partitions…"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11"
                                       Foreground="{DynamicResource Text3}" />
                            <Border Background="{DynamicResource Bg3}"
                                    BorderBrush="{DynamicResource Border}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="3,0"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="/"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="9"
                                           Foreground="{DynamicResource Text3}" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Separator -->
                <Border Grid.Column="4" Width="1" Height="18" Background="{DynamicResource Border}"
                        Margin="12,0" VerticalAlignment="Center" />

                <!-- Legend -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="OK"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Text3}"
                               VerticalAlignment="Center" />
                    <Border Width="10" Height="10"
                            BorderBrush="{DynamicResource Accent}"
                            BorderThickness="1"
                            Margin="4,0,10,0"
                            VerticalAlignment="Center" />
                    <TextBlock Text="Refreshing"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Text3}"
                               VerticalAlignment="Center" />
                    <Border Width="10" Height="10"
                            BorderBrush="{DynamicResource Info}"
                            BorderThickness="1"
                            Margin="4,0,10,0"
                            VerticalAlignment="Center" />
                    <TextBlock Text="Failed"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Text3}"
                               VerticalAlignment="Center" />
                    <Border Width="10" Height="10"
                            BorderBrush="{DynamicResource Error}"
                            BorderThickness="1"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center" />
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Column="6" Width="1" Height="18" Background="{DynamicResource Border}"
                        Margin="12,0" VerticalAlignment="Center" />

                <!-- Right: Backup + Reload + refresh status -->
                <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding RefreshStatus}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Accent}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RefreshStatus}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Content="↺ Reload"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding ReloadCommand}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════ CONTENT ═══════════════════════════════ -->
        <Grid Grid.Row="1">

            <!-- Pulsing bar: shows for both first-load and background refresh -->
            <Border Height="2" VerticalAlignment="Top" Panel.ZIndex="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBackgroundRefreshing}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Rectangle Fill="{DynamicResource Accent}">
                    <Rectangle.Triggers>
                        <EventTrigger RoutedEvent="Rectangle.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.25" To="1.0"
                                                     Duration="0:0:0.8"
                                                     AutoReverse="True" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Rectangle.Triggers>
                </Rectangle>
            </Border>

            <!-- Loading indicator (only when no cached data is shown) -->
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibleConverter}}">
                <!-- Centred label -->
                <TextBlock Text="Loading partitions…"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="12"
                           Foreground="{DynamicResource Text2}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Error state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="32"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}">
                <TextBlock Text="Failed to load partitions"
                           FontFamily="{StaticResource SansFont}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Error}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="11"
                           Foreground="{DynamicResource Text2}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="480"
                           Margin="0,8,0,0" />
                <Button Content="Retry"
                        Style="{StaticResource FlatButton}"
                        Command="{Binding ReloadCommand}"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0" />
            </StackPanel>

            <!-- Empty filter result -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding VisibleTables.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                <TextBlock Text="No partitions match this filter"
                           FontFamily="{StaticResource SansFont}"
                           FontSize="13"
                           Foreground="{DynamicResource Text2}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Partition table list — hidden while loading or when an error is shown -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="0,4,0,12">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <!-- visible when no error — handled by outer logic -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <ItemsControl ItemsSource="{Binding VisibleTables}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TableViewModel}">

                            <!-- ── TABLE ROW ── -->
                            <Border Margin="12,4,12,0"
                                    BorderBrush="{DynamicResource Border}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Background="{DynamicResource Bg1}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- Fixed info panel -->
                                        <ColumnDefinition Width="148" />
                                        <!-- Partition tiles -->
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- ── LEFT: table info — click to select/deselect all partitions ── -->
                                    <Border Grid.Column="0"
                                            Padding="12,8,10,8"
                                            BorderBrush="{DynamicResource Border}"
                                            BorderThickness="0,0,1,0"
                                            Cursor="Hand"
                                            ToolTip="Click to select / deselect all partitions">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.ToggleTableSelectionCommand,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Bg2}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TableName}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource Text0}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding TableName}" />
                                            <TextBlock Text="{Binding DisplayRowCount}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Text2}"
                                                       Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding DisplaySize}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Text3}" />
                                            <TextBlock Text="{Binding DisplayLastRefreshed}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource Text3}"
                                                       Opacity="0.7"
                                                       Margin="0,5,0,0" />
                                            <TextBlock Text="{Binding PartitionLabel}"
                                                       FontFamily="{StaticResource SansFont}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource Text3}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <!-- ── RIGHT: partition tiles ── -->
                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Partitions}" Margin="4,6,6,6">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:PartitionCellViewModel}">

                                                <!-- ── PARTITION CELL ── -->
                                                <Border Width="108" Height="60"
                                                        Margin="2"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        ToolTip="{Binding ToolTip}"
                                                        Cursor="Hand"
                                                        ClipToBounds="True">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.ToggleSelectionCommand,
                                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}" />
                                                    </Border.InputBindings>

                                                    <!-- State-driven border + background -->
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <!-- Default: Ok -->
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.09" />
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Setter Property="Opacity" Value="1.0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding State}"
                                                                             Value="{x:Static model:PartitionState.Stale}">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Text3}" />
                                                                    <Setter Property="Background" Value="Transparent" />
                                                                    <Setter Property="Opacity" Value="0.55" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}"
                                                                             Value="{x:Static model:PartitionState.Failed}">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Error}" />
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="{DynamicResource ErrorColor}" Opacity="0.09" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}"
                                                                             Value="{x:Static model:PartitionState.Refreshing}">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Info}" />
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="{DynamicResource InfoColor}" Opacity="0.09" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding State}"
                                                                             Value="{x:Static model:PartitionState.Queued}">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Warn}" />
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="{DynamicResource WarnColor}" Opacity="0.09" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                                <!-- Selected: thicker accent border, slightly brighter bg -->
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.18" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <!-- Cell content -->
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" />
                                                            <!-- fill bar -->
                                                            <RowDefinition Height="3" />
                                                        </Grid.RowDefinitions>

                                                        <!-- Text content -->
                                                        <StackPanel Grid.Row="0" Margin="6,4,4,2" VerticalAlignment="Top">
                                                            <TextBlock Text="{Binding PartitionName}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="10"
                                                                       FontWeight="Medium"
                                                                       Foreground="{DynamicResource Text0}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding PartitionName}" />
                                                            <TextBlock Text="{Binding DisplayRowCount}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="9"
                                                                       Foreground="{DynamicResource Text2}"
                                                                       Margin="0,2,0,0" />
                                                            <TextBlock Text="{Binding DisplaySize}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="9"
                                                                       Foreground="{DynamicResource Text3}" />
                                                            <TextBlock Text="{Binding DisplayLastRefreshed}"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       FontSize="8"
                                                                       Foreground="{DynamicResource Text3}"
                                                                       Opacity="0.7"
                                                                       Margin="0,1,0,0" />
                                                        </StackPanel>

                                                        <!-- Fill bar at bottom -->
                                                        <Border Grid.Row="1"
                                                                x:Name="FillTrack"
                                                                Background="{DynamicResource Bg3}">
                                                            <Border HorizontalAlignment="Left"
                                                                    Background="{DynamicResource AccentDim}">
                                                                <Border.Width>
                                                                    <MultiBinding Converter="{StaticResource RatioWidthMultiConverter}">
                                                                        <Binding Path="ActualWidth"
                                                                                 RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=1}" />
                                                                        <Binding Path="FillRatio" />
                                                                    </MultiBinding>
                                                                </Border.Width>
                                                            </Border>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </Grid>
                            </Border>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ═══════════════ SELECTION TRAY (floats above content) ═══════════════ -->
            <!-- Slides up from the bottom when partitions are selected.
                 Contains count/clear, per-mode refresh shortcuts, and Backup. -->
            <Border VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16"
                    Panel.ZIndex="20"
                    Background="{DynamicResource Bg2}"
                    BorderBrush="{DynamicResource BorderStrong}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <!-- Visible by default; collapsed when nothing is selected -->
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedCount}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Count + clear -->
                    <TextBlock FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{DynamicResource Text1}"
                               VerticalAlignment="Center">
                        <Run Text="{Binding SelectedCount, Mode=OneWay}" />
                        <Run Text=" selected" />
                    </TextBlock>
                    <Button Content="· clear"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding ClearSelectionCommand}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Foreground="{DynamicResource Text3}"
                            Padding="4,2"
                            Margin="2,0,0,0"
                            VerticalAlignment="Center" />

                    <!-- Separator -->
                    <Border Width="1" Height="18" Background="{DynamicResource Border}"
                            Margin="12,0" VerticalAlignment="Center" />

                    <!-- Refresh type shortcuts -->
                    <TextBlock Text="Refresh as:"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Text3}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />

                    <Button Style="{StaticResource FlatButton}"
                            Command="{Binding RefreshWithModeCommand}"
                            CommandParameter="{Binding RefreshTypeOptions[0]}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Padding="8,3"
                            Margin="0,0,2,0">
                        <TextBlock><Run Text="⟳ " /><Run Text="{Binding RefreshTypeOptions[0].DisplayName}" /></TextBlock>
                    </Button>
                    <Button Style="{StaticResource FlatButton}"
                            Command="{Binding RefreshWithModeCommand}"
                            CommandParameter="{Binding RefreshTypeOptions[1]}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Padding="8,3"
                            Margin="0,0,2,0">
                        <TextBlock><Run Text="⟳ " /><Run Text="{Binding RefreshTypeOptions[1].DisplayName}" /></TextBlock>
                    </Button>
                    <Button Style="{StaticResource FlatButton}"
                            Command="{Binding RefreshWithModeCommand}"
                            CommandParameter="{Binding RefreshTypeOptions[2]}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Padding="8,3"
                            Margin="0,0,2,0">
                        <TextBlock><Run Text="⟳ " /><Run Text="{Binding RefreshTypeOptions[2].DisplayName}" /></TextBlock>
                    </Button>
                    <Button Style="{StaticResource FlatButton}"
                            Command="{Binding RefreshWithModeCommand}"
                            CommandParameter="{Binding RefreshTypeOptions[3]}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Padding="8,3"
                            Margin="0,0,2,0">
                        <TextBlock><Run Text="⟳ " /><Run Text="{Binding RefreshTypeOptions[3].DisplayName}" /></TextBlock>
                    </Button>
                    <Button Style="{StaticResource FlatButton}"
                            Command="{Binding RefreshWithModeCommand}"
                            CommandParameter="{Binding RefreshTypeOptions[4]}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Padding="8,3">
                        <TextBlock><Run Text="⟳ " /><Run Text="{Binding RefreshTypeOptions[4].DisplayName}" /></TextBlock>
                    </Button>


                </StackPanel>
            </Border>

        </Grid>
    </Grid>

</UserControl>
