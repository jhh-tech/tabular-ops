<UserControl x:Class="TabularOps.Desktop.Views.TraceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TabularOps.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource Bg0}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- ── Main trace area ── -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Bg1}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Status indicator -->
                        <Ellipse Width="7" Height="7"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource Text3}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource Accent}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasError}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource Error}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <TextBlock Text="{Binding StatusMessage}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource Text2}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0" />

                        <TextBlock Text="{Binding Events.Count, StringFormat='{}{0} events'}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="10"
                                   Foreground="{DynamicResource Text3}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0" />

                        <!-- Filter chips -->
                        <Border Background="{DynamicResource Bg3}"
                                CornerRadius="3"
                                Padding="8,3"
                                Margin="0,0,6,0"
                                Cursor="Hand"
                                MouseLeftButtonDown="OnFilterChipClick"
                                Tag="Progress">
                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Progress" />
                                        <Setter Property="Foreground" Value="{DynamicResource Text3}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FilterProgress}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Border Background="{DynamicResource Bg3}"
                                CornerRadius="3"
                                Padding="8,3"
                                Margin="0,0,6,0"
                                Cursor="Hand"
                                MouseLeftButtonDown="OnFilterChipClick"
                                Tag="Query">
                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Query" />
                                        <Setter Property="Foreground" Value="{DynamicResource Text3}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FilterQuery}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Border Background="{DynamicResource Bg3}"
                                CornerRadius="3"
                                Padding="8,3"
                                Margin="0,0,6,0"
                                Cursor="Hand"
                                MouseLeftButtonDown="OnFilterChipClick"
                                Tag="Errors">
                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Errors" />
                                        <Setter Property="Foreground" Value="{DynamicResource Text3}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FilterErrors}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Border Background="{DynamicResource Bg3}"
                                CornerRadius="3"
                                Padding="8,3"
                                Margin="0,0,6,0"
                                Cursor="Hand"
                                MouseLeftButtonDown="OnFilterChipClick"
                                Tag="Lock">
                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Lock" />
                                        <Setter Property="Foreground" Value="{DynamicResource Text3}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FilterLock}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <Border Background="{DynamicResource Bg3}"
                                CornerRadius="3"
                                Padding="8,3"
                                Cursor="Hand"
                                MouseLeftButtonDown="OnFilterChipClick"
                                Tag="Audit">
                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Audit" />
                                        <Setter Property="Foreground" Value="{DynamicResource Text3}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FilterAudit}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Right-side buttons -->
                    <StackPanel HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource FlatButton}"
                                Command="{Binding ClearEventsCommand}"
                                FontFamily="{StaticResource MonoFont}"
                                FontSize="11"
                                Margin="0,0,8,0"
                                Content="Clear" />
                        <Button Style="{StaticResource FlatButton}"
                                Command="{Binding StopTraceCommand}"
                                FontFamily="{StaticResource MonoFont}"
                                FontSize="11"
                                Margin="0,0,8,0"
                                Content="Stop"
                                Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibleConverter}}" />
                        <Button Style="{StaticResource FlatButton}"
                                Command="{Binding StartTraceCommand}"
                                FontFamily="{StaticResource MonoFont}"
                                FontSize="11"
                                Content="Start"
                                Visibility="{Binding IsRunning, Converter={StaticResource BoolToCollapsedConverter}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Event list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding EventsView}"
                     SelectedItem="{Binding SelectedEvent}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            BorderBrush="{DynamicResource Border}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,5,12,5">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg3}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bg2}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TraceEventViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>

                            <!-- Time -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Time}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       Foreground="{DynamicResource Text3}"
                                       VerticalAlignment="Center" />

                            <!-- Event class -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Summary}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource Text2}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource Error}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Text / scope -->
                            <TextBlock Grid.Column="2"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       Foreground="{DynamicResource Text1}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Text}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text}" Value="{x:Null}">
                                                <Setter Property="Text" Value="{Binding Scope}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Duration -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Duration}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       Foreground="{DynamicResource Text3}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right" />

                            <!-- Row count -->
                            <TextBlock Grid.Column="4"
                                       Text="{Binding RowCount}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="10"
                                       Foreground="{DynamicResource Text3}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right" />
                            </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state: no events yet -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsRunning}" Value="False" />
                                    <Condition Binding="{Binding Events.Count}" Value="0" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="No trace events"
                           FontFamily="{StaticResource SansFont}"
                           FontSize="13"
                           Foreground="{DynamicResource Text2}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Click Start to begin live trace collection"
                           FontFamily="{StaticResource MonoFont}"
                           FontSize="11"
                           Foreground="{DynamicResource Text3}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- ── Detail pane (resizable) ── -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource Border}"
                      Cursor="SizeWE"
                      Visibility="{Binding SelectedEvent, Converter={StaticResource NullToCollapsedConverter}}" />

        <!-- Detail panel -->
        <Border Grid.Column="1"
                Width="280"
                Background="{DynamicResource Bg1}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="1,0,0,0"
                Visibility="{Binding SelectedEvent, Converter={StaticResource NullToCollapsedConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                <StackPanel>
                    <!-- Event class -->
                    <TextBlock Text="Event"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               Margin="0,0,0,2" />
                    <TextBlock Text="{Binding SelectedEvent.EventClass}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="12"
                               Foreground="{DynamicResource Text1}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10" />

                    <!-- Subclass -->
                    <TextBlock Text="Subclass"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               Margin="0,0,0,2"
                               Visibility="{Binding SelectedEvent.EventSubclass, Converter={StaticResource NullToCollapsedConverter}}" />
                    <TextBlock Text="{Binding SelectedEvent.EventSubclass}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{DynamicResource Text2}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Visibility="{Binding SelectedEvent.EventSubclass, Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- Time -->
                    <TextBlock Text="Time"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               Margin="0,0,0,2" />
                    <TextBlock Text="{Binding SelectedEvent.Time}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{DynamicResource Text1}"
                               Margin="0,0,0,10" />

                    <!-- Scope (table/partition) -->
                    <TextBlock Text="Scope"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               Margin="0,0,0,2"
                               Visibility="{Binding SelectedEvent.TableName, Converter={StaticResource NullToCollapsedConverter}}" />
                    <TextBlock Text="{Binding SelectedEvent.Scope}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{DynamicResource Text1}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Visibility="{Binding SelectedEvent.TableName, Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- Duration -->
                    <TextBlock Text="Duration"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               Margin="0,0,0,2"
                               Visibility="{Binding SelectedEvent.Duration, Converter={StaticResource NullToCollapsedConverter}}" />
                    <TextBlock Text="{Binding SelectedEvent.Duration}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{DynamicResource Text1}"
                               Margin="0,0,0,10"
                               Visibility="{Binding SelectedEvent.Duration, Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- CPU -->
                    <TextBlock Text="CPU"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               Margin="0,0,0,2"
                               Visibility="{Binding SelectedEvent.CpuMs, Converter={StaticResource NullToCollapsedConverter}}" />
                    <TextBlock Text="{Binding SelectedEvent.CpuMs}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{DynamicResource Text1}"
                               Margin="0,0,0,10"
                               Visibility="{Binding SelectedEvent.CpuMs, Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- Rows -->
                    <TextBlock Text="Rows"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               Margin="0,0,0,2"
                               Visibility="{Binding SelectedEvent.RowCount, Converter={StaticResource NullToCollapsedConverter}}" />
                    <TextBlock Text="{Binding SelectedEvent.RowCount}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{DynamicResource Text1}"
                               Margin="0,0,0,10"
                               Visibility="{Binding SelectedEvent.RowCount, Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- Error code -->
                    <TextBlock Text="Error code"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               Margin="0,0,0,2"
                               Visibility="{Binding SelectedEvent.ErrorCode, Converter={StaticResource NullToCollapsedConverter}}" />
                    <TextBlock Text="{Binding SelectedEvent.ErrorCode}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               Foreground="{DynamicResource Error}"
                               Margin="0,0,0,10"
                               Visibility="{Binding SelectedEvent.ErrorCode, Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- Session ID -->
                    <TextBlock Text="Session ID"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               Margin="0,0,0,2"
                               Visibility="{Binding SelectedEvent.SessionId, Converter={StaticResource NullToCollapsedConverter}}" />
                    <TextBlock Text="{Binding SelectedEvent.SessionId}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Visibility="{Binding SelectedEvent.SessionId, Converter={StaticResource NullToCollapsedConverter}}" />

                    <!-- Text -->
                    <TextBlock Text="Text"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="9"
                               Foreground="{DynamicResource Text3}"
                               Margin="0,0,0,2"
                               Visibility="{Binding SelectedEvent.Text, Converter={StaticResource NullToCollapsedConverter}}" />
                    <TextBlock Text="{Binding SelectedEvent.Text}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Text1}"
                               TextWrapping="Wrap"
                               Visibility="{Binding SelectedEvent.Text, Converter={StaticResource NullToCollapsedConverter}}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
