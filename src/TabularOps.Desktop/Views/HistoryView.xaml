<UserControl x:Class="TabularOps.Desktop.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:TabularOps.Desktop.ViewModels"
             xmlns:views="clr-namespace:TabularOps.Desktop.Views"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{DynamicResource Bg0}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="160" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Bg1}"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Dataset name -->
                    <TextBlock Text="{Binding ModelName}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Text1}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ModelName}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Runs.Count, StringFormat='{}{0} entries'}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Text3}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0" />
                    <TextBlock Text="{Binding SyncError}"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="10"
                               Foreground="{DynamicResource Error}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SyncError}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⟳ Sync from workspace"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding SyncFromWorkspaceCommand}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Margin="0,0,8,0"
                            Visibility="{Binding CanSyncFromWorkspace, Converter={StaticResource BoolToVisibleConverter}}" />
                    <Button Content="↺ Reload"
                            Style="{StaticResource FlatButton}"
                            Command="{Binding RefreshCommand}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Chart -->
        <views:RefreshChartControl Grid.Row="1"
                                   Runs="{Binding Runs}"
                                   Margin="12,6,12,6" />

        <!-- Loading -->
        <TextBlock Grid.Row="2"
                   Text="Loading history…"
                   FontFamily="{StaticResource MonoFont}"
                   FontSize="12"
                   Foreground="{DynamicResource Text2}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibleConverter}}" />

        <!-- Empty state -->
        <TextBlock Grid.Row="2"
                   Text="No refresh history yet"
                   FontFamily="{StaticResource SansFont}"
                   FontSize="13"
                   Foreground="{DynamicResource Text3}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsLoading}" Value="False" />
                                <Condition Binding="{Binding Runs.Count}" Value="0" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- History list -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,4,0,12"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToCollapsedConverter}}">

            <ItemsControl ItemsSource="{Binding Runs}" Margin="12,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:RefreshRunViewModel}">
                        <Border Margin="0,2,0,0"
                                Padding="12,8"
                                BorderBrush="{DynamicResource Border}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>

                                <!-- Scope: "Full model" or "Table · Partition" -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayScope}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource Text0}" />
                                    <TextBlock Text="{Binding RefreshType}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="10"
                                               Foreground="{DynamicResource Text3}"
                                               VerticalAlignment="Center"
                                               Margin="2,0,0,0" />
                                    <!-- "Workspace" source badge -->
                                    <Border Margin="8,0,0,0"
                                            Padding="4,1"
                                            CornerRadius="2"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsWorkspace, Converter={StaticResource BoolToVisibleConverter}}">
                                        <Border.Background>
                                            <SolidColorBrush Color="{DynamicResource InfoColor}" Opacity="0.12" />
                                        </Border.Background>
                                        <TextBlock Text="workspace"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="9"
                                                   Foreground="{DynamicResource Info}" />
                                    </Border>
                                </StackPanel>

                                <!-- Duration -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Duration}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Text2}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />

                                <!-- Status badge -->
                                <Border Grid.Column="2"
                                        CornerRadius="2"
                                        Padding="6,2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="{DynamicResource AccentColor}" Opacity="0.15" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <SolidColorBrush Color="{DynamicResource ErrorColor}" Opacity="0.15" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontFamily="{StaticResource MonoFont}"
                                               FontSize="10"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Status}" />
                                                <Setter Property="Foreground" Value="{DynamicResource Text2}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource Error}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- Started at -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding StartedAt}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="10"
                                           Foreground="{DynamicResource Text3}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
